# FHIR server connection
FHIR_BASE_URL=http://localhost:8082/fhir

# Synthea generation (used by scripts/load_synthea.py)
SYNTHEA_POOL_SIZE=200
SYNTHEA_FINAL_SIZE=20
SYNTHEA_SEEDS_FILE=data/synthea-config/seeds.txt

# Output directory for generated Synthea bundles (gitignored)
# Synthea writes to a fhir/ subdirectory inside the base dir, so actual bundles
# land at out/synthea/fhir/fhir/ — point OUTPUT_DIR at that inner fhir/ folder.
SYNTHEA_OUTPUT_DIR=out/synthea/fhir/fhir

# Tag applied to all loaded resources (used for idempotent re-loads)
SYNTHEA_LOAD_TAG=synthea-v1

# mcp-fhir settings (used by src/prior_auth_copilot/evidence/tools.py)
# HAPI_VALIDATOR_URL must NOT collide with FHIR_BASE_URL (8082).
# Port 8083 is reserved for the HAPI validator sidecar (Phase 4.4).
# Leave unset in Phase 4.2 — validate_against_profile is not called yet.
HAPI_VALIDATOR_URL=http://localhost:8083
FHIR_MAX_RESULTS=50
FHIR_TIMEOUT_S=30
LOG_FORMAT=console

# OpenAI — required for Evidence Gatherer LLM second pass
OPENAI_API_KEY=sk-...            # replace with your key
OPENAI_MODEL=gpt-4o-mini         # Evidence Gatherer second pass

# Phase 4.3 — Reasoner + RAG
REASONER_MODEL=gpt-4o            # upgrade from gpt-4o-mini for multi-step clinical reasoning
OPENAI_EMBED_MODEL=text-embedding-3-small
POLICY_STORE_DIR=data/policy-store  # LanceDB data dir (gitignored; rebuild: make ingest-policies)
TOP_K_POLICY_CHUNKS=8            # number of policy paragraphs retrieved per Reasoner call

# Phase 4.4 — Bundle Builder + Reviewer HITL + Mock Payer
PAYER_FHIR_BASE_URL=http://localhost:8090/fhir   # mock payer HAPI (port 8090, per ADR-0009)
CHECKPOINT_DB=data/checkpoints/pa.db             # SQLite checkpoint file (ADR-0008)
MOCK_PAYER_PORT=8091                              # FastAPI mock_payer.py listen port

# LangSmith tracing (optional — leave unset to disable)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...       # your LangSmith API key
# LANGCHAIN_PROJECT=prior-auth-copilot
